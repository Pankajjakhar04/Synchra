# Environment Variables for SYNCHRA Backend
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Cloud Storage (for file uploads)
GCS_BUCKET_NAME=synchra-videos
GOOGLE_CLOUD_PROJECT=synchra-prod

# TURN Server (optional for MVP — use Metered.ca free tier)
TURN_USERNAME=
TURN_PASSWORD=
TURN_URL=

# Secret for signing room tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-here
